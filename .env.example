# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual credentials.
#
# Your Databricks AI Gateway base URL.
# Found in: Databricks workspace → AI Gateway → your endpoint → "View endpoint details"
# Format: https://<workspace-id>.ai-gateway.azuredatabricks.net
# (A full endpoint URL still works and will be normalized by the proxy.)
DATABRICKS_AI_GATEWAY_URL=https://<workspace-id>.ai-gateway.azuredatabricks.net
