# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual credentials.
#
# Your Databricks AI Gateway chat completions endpoint.
# Found in: Databricks workspace → AI Gateway → your endpoint → "View endpoint details"
# Format: https://<workspace-id>.ai-gateway.azuredatabricks.net/mlflow/v1/chat/completions
DATABRICKS_AI_GATEWAY_URL=https://<workspace-id>.ai-gateway.azuredatabricks.net/mlflow/v1/chat/completions
